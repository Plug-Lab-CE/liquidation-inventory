DATABASE_URL=postgresql://user:password@localhost:5432/liquidation
AUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true

# Local only: skip login and use a fake admin session (never enable in production)
# AUTH_DEV_BYPASS=true
# AUTH_URL=http://localhost:3000

# Optional: OpenAI for manifest normalization and image discovery
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional: Shopify Admin API (custom app)
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com
SHOPIFY_ACCESS_TOKEN=

# Upload directory for CSVs (default: ./data/uploads)
# UPLOAD_DIR=

# Limits
# MAX_CSV_BYTES=5242880
# MAX_CSV_ROWS=10000
# ITEMS_PAGE_SIZE=24
